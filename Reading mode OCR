BUTTON + MODE CONTROL (ESP32 CODE)
#define buttonPin 4

bool readingMode = false;

void setup() {
  pinMode(buttonPin, INPUT_PULLUP);
  Serial.begin(115200);
}

void loop() {
  if (digitalRead(buttonPin) == LOW) {
    delay(300); // debounce
    readingMode = true;
    Serial.println("READ_MODE");
  }

  if (readingMode) {
    // Trigger camera capture
    Serial.println("CAPTURE_IMAGE");

    delay(2000); // wait before next read
    readingMode = false;
  }
}


